# Local developer secrets — copy to .env (gitignored) and fill in values.
# Non-secret config lives in visdom.toml; env vars here override the file.

# Anthropic API key — required for live integration tests and production use.
# The key is never logged or persisted; only the model name and request shape are recorded.
# ANTHROPIC_API_KEY=sk-ant-...

# Override the Anthropic model (default is in visdom.toml)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Override server config if needed (defaults in visdom.toml)
# BIND_ADDR=127.0.0.1:3001
# DATABASE_URL=sqlite://visdom.db?mode=rwc
# RUST_LOG=info,visdom_harness=debug

# To run the live Anthropic round-trip integration test:
#   cargo test --test debug_infer_live -- --ignored --nocapture
