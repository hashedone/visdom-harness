# Bind address for the HTTP server
BIND_ADDR=127.0.0.1:3000

# SQLite database URL; mode=rwc creates the file if it does not exist
DATABASE_URL=sqlite://visdom.db?mode=rwc

# Log filter passed to tracing-subscriber's EnvFilter
RUST_LOG=info,visdom_harness=debug

# Anthropic API key — required for live integration tests.
# The key is never logged or persisted; only the model name and request shape are recorded.
# ANTHROPIC_API_KEY=sk-ant-...

# To run the live Anthropic round-trip integration test:
#   ANTHROPIC_API_KEY=sk-ant-... cargo test --test debug_infer_live -- --ignored --nocapture
